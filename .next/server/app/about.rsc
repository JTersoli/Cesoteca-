7:["$","main",null,{"className":"page_page__NuxqY","children":[["$","img",null,{"className":"page_fixedPortrait__CvlNT","aria-hidden":"true","src":"/about-diablo-cropped.jpeg","alt":""}],["$","div",null,{"className":"page_content__QCmPY","children":[["$","$L6",null,{"href":"/","className":"page_backLink__39rnC","children":"← Volver"}],["$","h1",null,{"className":"page_title__yVhH_","children":"Sobre mí"}],[["$","p","0",{"className":"page_body__te9P1","children":"La cesoteca es este espacio virtual donde comparto escritos, comentarios de libros, poemas, ensayos y artículos personales. Pero la cesoteca no siempre fue así. Empezó hace unos años como un perfil de instagram donde compartía comentarios de textos de los libros que leía y más me llamaban la atención. Como todo, con el tiempo se fue modificando y empecé a publicar algunos escritos personales, algunos poemas, y otras cosas que quería compartir. Hacía tiempo que quería reunir todo mi trabajo y darle una forma por fuera de la plataforma de instagram, y así surgió la idea de armar este sitio web."}]],["$","p",null,{"className":"page_credits__j33aA","children":"Dibujos: Luciana Minen"}],["$","hr",null,{"className":"page_divider__p_IIG"}],["$","p",null,{"className":"page_sectionLabel__SvNvA","children":"Contacto"}],["$","section",null,{"className":"page_card__qEc71","aria-label":"Contacto","children":[["$","div",null,{"className":"page_services__gYQxO","children":[["$","span","Clases de español",{"className":"page_serviceItem__S_gZg","children":"Clases de español"}],["$","span","Acompañamiento de escritura",{"className":"page_serviceItem__S_gZg","children":"Acompañamiento de escritura"}],["$","span","Corrección de textos académicos y no académicos",{"className":"page_serviceItem__S_gZg","children":"Corrección de textos académicos y no académicos"}]]}],["$","div",null,{"className":"page_contactRow___64vj","children":[["$","span",null,{"className":"page_contactLabel__xB1Bt","children":"Email"}],["$","span",null,{"cl