7:["$","main",null,{"className":"page_page__NuxqY","children":[["$","div",null,{"className":"page_devilDecoration__iRKZ5","aria-hidden":"true"}],["$","div",null,{"className":"page_content__QCmPY","children":[["$","$L6",null,{"href":"/","className":"page_backButton__vRtq1","children":"← Volver"}],["$","section",null,{"className":"page_hero__kIiS8","aria-labelledby":"about-title","children":[["$","div",null,{"className":"page_heroCopy__so3tV","children":[["$","h1",null,{"id":"about-title","className":"page_name__qYz2P","children":"Sobre mí"}],["$","p",null,{"className":"page_tagline__zf9NY","children":"La cesoteca es este espacio virtual donde comparto escritos, comentarios de libros, poemas, ensayos y artículos personales. Pero la cesoteca no siempre fue así. Empezó hace unos años como un perfil de instagram donde compartía comentarios de textos de los libros que leía y más me llamaban la atención. Como todo, con el tiempo se fue modificando y empecé a publicar algunos escritos personales, algunos poemas, y otras cosas que quería compartir. Hacía tiempo que quería reunir todo mi trabajo y darle una forma por fuera de la plataforma de instagram, y así surgió la idea de armar este sitio web."}]]}],["$","div",null,{"className":"page_portrait__HDg_V","aria-hidden":"true","style":{"backgroundImage":"url(\"/about-diablo-cropped.jpeg\")"}}]]}],["$","hr",null,{"className":"page_divider__p_IIG"}],["$","section",null,{"className":"page_bioServices__wehIb","aria-label":"Biografía y servicios","children":[["$","div",null,{"className":"page_bioColumn__drfws","children":[["$","p",null,{"className":"page_label__mBHE6","children":"Biografía"}],["$","div",null,{"className":"page_bioText__Bkf_8","children":[["$","p","0",{"children":"La cesoteca es este espacio virtual donde comparto escritos, comentarios de libros, poemas, ensayos y artículos personales. Pero la cesoteca no siempre fue así. Empezó hace unos años como un perfil de instagram donde compartía comentarios de textos de los libros que leía y más me llamaban la atención. Como todo, con el tiempo se fue modificando y empecé a publicar algunos escritos personales, algunos poemas, y otras cosas que quería compartir. Hacía tiempo que quería reunir todo mi trabajo y darle una forma por fuera de la plataforma de instagram, y así surgió la idea de armar este sitio web."}]]}],["$","p",null,{"className":"page_credits__j33aA","children":"Dibujos: Luciana Minen"}]]}],["$","aside",null,{"className":"page_servicesColumn__wOUqH","aria-label":"Servicios","children":[["$","p",null,{"className":"page_label__mBHE6","children":"Servicios"}],[["$","div","Clases de español",{"className":"page_card__qEc71","children":"Clases de español"}],["$","div","Acompañamiento de escritura",{"className":"page_card__qEc71","children":"Acompañamiento de escritura"}],["$","div","Corrección de textos académicos y no académicos",{"className":"page_card__qEc71","children":"Corrección de textos académicos y no académicos"}]]]}]]}],["$","hr",null,{"className":"page_divider__p_IIG"}],["$","section",null,{"className":"page_contacts__PpHOb","aria-label":"Contacto","children":[["$","div",null,{"children":[["$","span",null,{"className":"page_contactLabel__xB1Bt","children":"Email"}],["$","span",null,{"className":"page_contactValue__mjj0z","children":"bonet.ceci@gmail.com"}]]}],["$","div",null,{"children":[["$","span",null,{"className":"page_contactLabel__xB1Bt","children":"Teléfono"}],["$","span",null,{"className":"page_contactValue__mjj0z","children":"+61 0493332140"}]]}],["$","div",null,{"children":[["$","span",null,{"className":"page_contactLabel__xB1Bt","children":"Instagram"}],["$","span",null,{"className":"page_contactValue__mjj0z","children":"/cesoteca"}]]}]]}],["$","hr",null,{"className":"page_divider__p_IIG"}],["$","section",null,{"className":"page_cvBar__cwtU9","aria-label":"Curriculum","children":[["$","div",null,{"children":[["$","p",null,{"className":"page_label__mBHE6","children":"Curriculum"}],["$","p",null,{"classNam