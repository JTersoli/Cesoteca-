{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/essays/[slug]",
      "regex": "^/essays/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/essays/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/poems/[slug]",
      "regex": "^/poems/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/poems/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/publications/academic/[slug]",
      "regex": "^/publications/academic/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/publications/academic/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/publications/non-academic/[slug]",
      "regex": "^/publications/non\\-academic/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/publications/non\\-academic/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/text-comments/[slug]",
      "regex": "^/text\\-comments/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/text\\-comments/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/writings/[slug]",
      "regex": "^/writings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/writings/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/admin",
