      "namedRegex": "^/admin/poems/editor(?:/)?$"
    },
    {
      "page": "/essays",
      "regex": "^/essays(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/essays(?:/)?$"
    },
    {
      "page": "/poems",
      "regex": "^/poems(?:/)?$",
