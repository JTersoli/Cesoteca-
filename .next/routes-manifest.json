    },
    {
      "page": "/publications/non-academic",
      "regex": "^/publications/non\\-academic(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/publications/non\\-academic(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/stitch",
      "regex": "^/stitch(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stitch(?:/)?$"
